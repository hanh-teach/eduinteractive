rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Session isolation: Users can only read their own session data
    // Real production rules would use auth.uid
    
    match /event_store/{eventId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null; // Only system should write, but client might ingest
      allow update, delete: if false; // Immutable ledger
    }
    
    match /session_states/{sessionId} {
      allow read, write: if request.auth != null && (
        request.auth.uid == resource.data.studentId || 
        request.auth.token.email != null
      );
      // Allows create if they are creating their own
      allow create: if request.auth != null && (
        request.auth.uid == request.resource.data.studentId ||
        request.auth.token.email != null
      );
    }
    
    match /evidence_artifacts/{evidenceId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false; // Immutable
    }
    
    match /competency_states/{stateId} {
      allow read: if request.auth != null;
      allow write: if false; // Only server-side CompetencyEngine should update
    }

    match /teachers/{teacherId} {
      allow read, write: if false; // Only accessible via Admin SDK on server
    }
  }
}
